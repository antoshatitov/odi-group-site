# Backend
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
TELEGRAM_CALC_BOT_TOKEN=YOUR_TELEGRAM_CALC_BOT_TOKEN_HERE
TELEGRAM_CALC_CHAT_ID=YOUR_TELEGRAM_CALC_CHAT_ID_HERE
TELEGRAM_QUARANTINE_CHAT_ID=YOUR_TELEGRAM_QUARANTINE_CHAT_ID_HERE
LOG_HASH_SALT=YOUR_LOG_HASH_SALT_HERE
CAPTCHA_ENABLED=false
CAPTCHA_SECRET_KEY=YOUR_CAPTCHA_SECRET_KEY_HERE
CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
CAPTCHA_EXPECTED_HOSTNAME=
TELEGRAM_TIMEOUT_MS=5000
TELEGRAM_RETRY_ATTEMPTS=2
TELEGRAM_RETRY_BASE_MS=400
# Behind nginx reverse proxy on production VPS.
TRUST_PROXY=true
# For local direct server run without reverse proxy use:
# TRUST_PROXY=false
IN_MEMORY_LIMITER_MAX_KEYS=5000
IN_MEMORY_DEDUP_MAX_KEYS=3000
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,https://example.com,https://www.example.com

# Frontend
VITE_API_BASE=http://localhost:8080
